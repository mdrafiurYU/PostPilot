{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@postpilot/types": [
        "../types/dist/index.d.ts"
      ],
      "@postpilot/events": [
        "../events/dist/index.d.ts"
      ],
      "@postpilot/*": [
        "../*"
      ]
    },
    "rootDir": "./src"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
